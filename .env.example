# =========================================================
# Silver Guard · 环境变量（开发/测试用）
# 使用：复制为 .env 后放到项目根目录
# 生产环境请替换为真实密码
# =========================================================

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=silver_guard_root_2026
DB_APP_PASSWORD=silver_guard_app_2026

# ---- Redis ----
REDIS_PASSWORD=silver_guard_redis_2026

# ---- JWT ----
JWT_SECRET=silver-guard-dev-secret-change-in-prod-please-change-it

# ---- LLM 大模型 API（OpenAI 兼容格式）----
# 支持 OpenAI / 通义千问 / DeepSeek / 智谱 等所有 OpenAI 兼容接口
# 配置后作曲、作词和知识库问答将使用真实 AI 生成，不配置则自动降级为模板匹配
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxx
LLM_API_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# 通义千问示例：
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxx
# LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# DeepSeek 示例：
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxx
# LLM_API_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# ---- 系统提示词（可选，不配置则使用内置默认）----
# 提示词支持 {var} 占位符变量替换
#
# 作曲提示词可用变量：{theme} {tempo} {style} {mood}
# LLM_COMPOSE_SYSTEM_PROMPT=你是一位音乐作曲家...
# LLM_COMPOSE_USER_PROMPT=请创作一首主题为{theme}的{style}乐曲...
#
# 作词提示词可用变量：{theme} {genre}
# LLM_LYRICS_SYSTEM_PROMPT=你是一位歌词创作人...
# LLM_LYRICS_USER_PROMPT=请创作一首主题为{theme}的{genre}歌词...
#
# 知识库问答提示词可用变量：{context} {question} {userInfo}
# LLM_RAG_SYSTEM_PROMPT=你是一位养老顾问...
# LLM_RAG_USER_PROMPT=根据以下知识库内容回答用户问题：{context}...
#
# 自定义知识库（JSON 数组格式，每条记录需包含 id/category/title/keywords/content）
# LLM_RAG_KNOWLEDGE=[{"id":1,"category":"健康","title":"示例","keywords":["示例"],"content":"示例内容"}]

# ---- 时区（全局）----
TZ=Asia/Shanghai
