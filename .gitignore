# =========================================================
# Silver Guard · .gitignore
# 语言：Java 21 / Spring Boot 3 / Maven
# 用途：指定不应被 Git 提交的文件和目录
# ============================================================

# ============================================================
# Java / Maven 编译产物
# ============================================================
*.class
*.jar
*.war
*.ear
*.nar
target/
build/
dist/
out/

# Maven 仓库缓存
*.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ============================================================
# IDE 配置文件（团队不应共享）
# ============================================================

# IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws
*.iws
out/

# Eclipse
.classpath
.project
.settings/
.factorypath
.springBeans
.sts4-cache/

# VSCode
.vscode/
*.swp
*.swo
*~

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# 语言服务器索引
.lsp/
.temp/

# ============================================================
# 日志与临时文件
# ============================================================
*.log
*.log.*
logs/
*.tmp
*.bak
*.swp
*.cache

# ============================================================
# 数据库与缓存
# ============================================================
*.db
*.sqlite
*.sqlite3
*.h2.db
*.h2.mv.db
*.h2.trace.db

# ============================================================
# 操作系统
# ============================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*.swp
*~

# ============================================================
# 环境变量文件（含敏感信息，绝对不可提交！）
# ============================================================
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
.credentials

# ============================================================
# Spring Boot 特定
# ============================================================
# 本地属性文件（个人测试用）
application-local.yml
application-local.properties
application-*.yml.bak
application-*.properties.bak

# ============================================================
# Docker 与 Kubernetes
# ============================================================
.dockerignore
*.dockerignore

# ============================================================
# 测试与覆盖率工具
# ============================================================
.coverage
.coveralls.yml
*.coverdata
*.coverprofile

# ============================================================
# Node（前端构建产物，若本仓库不含前端则可删除本节）
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dist/
.cache/
.parcel-cache/
.eslintcache

# ============================================================
# 其他
# ============================================================
# Git 合并冲突临时文件
*.orig

# 本地错误日志
hs_err_pid*
replay_pid*

# CRLF 行尾配置（由 .gitattributes 管理，此处忽略）

# 打包相关
*.tar.gz
*.zip
*.tar
*.rar
